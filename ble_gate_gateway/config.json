{
  "name": "BLE Gate Gateway",
  "version": "1.1.1",
  "slug": "ble_gate_gateway",
  "description": "BLE → MQTT gateway for nRF52840 gate and barrier controllers",
  "url": "https://github.com/ntv999/ble-relay-ha",
  "arch": ["aarch64", "amd64"],
  "build_from": {
    "aarch64": "ghcr.io/home-assistant/aarch64-base:latest",
    "amd64": "ghcr.io/home-assistant/amd64-base:latest"
  },
  "startup": "application",
  "boot": "auto",
  "init": false,
  "host_dbus": true,
  "privileged": ["NET_ADMIN", "NET_RAW", "SYS_ADMIN"],
  "usb": true,
  "options": {
    "mode": "gateway",
    "mqtt_host": "core-mosquitto",
    "mqtt_port": 1883,
    "mqtt_username": "",
    "mqtt_password": "",
    "ble_adapter": "hci1",
    "ble_scan_timeout": 15,
    "scan_show_all": false,
    "pair_address": "",
    "pair_name": "",
    "pair_on_connect": false,
    "log_level": "info",
    "devices": []
  },
  "schema": {
    "mode": "list(gateway|scan|pair)",
    "mqtt_host": "str",
    "mqtt_port": "port",
    "mqtt_username": "str",
    "mqtt_password": "str",
    "ble_adapter": "str",
    "ble_scan_timeout": "int(5,60)",
    "scan_show_all": "bool",
    "pair_address": "str?",
    "pair_name": "str?",
    "pair_on_connect": "bool",
    "log_level": "list(debug|info|warning|error)",
    "devices": [
      {
        "id": "str",
        "name": "str",
        "type": "list(gate|barrier)",
        "address": "str?",
        "discover_name": "str?"
      }
    ]
  }
}
